PORT=3000
# IP de esta máquina en la red local (se usa para CORS y mensajes de arranque)
IP=192.168.18.127
# Opcional: orígenes extra separados por coma
# ALLOWED_ORIGINS=http://192.168.50.152:3000,http://localhost:3000

# MongoDB (elige una)
# Local:
DBLOCAL=mongodb://localhost:27017/lasgambusinas
# O Atlas / otro servidor:
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/lasgambusinas?retryWrites=true&w=majority

NODE_ENV=development
JWT_SECRET=cambia-este-secreto-en-produccion

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
