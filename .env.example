PORT=3000
# IP de esta máquina en la LAN (opcional). Se usa para sugerir URLs y para ampliar ALLOWED_ORIGINS en modo estricto.
IP=192.168.18.127

# CORS / App Cocina y frontends en otros dispositivos:
# - Con NODE_ENV=development el backend acepta cualquier Origin (tablets, PCs en la misma red).
# - En producción (NODE_ENV=production) la lista es estricta salvo que actives:
#   CORS_RELAX_LAN=true
# O define orígenes explícitos, p. ej. la URL del PC que sirve React:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://192.168.1.10:3001

# MongoDB (elige una)
# Local:
DBLOCAL=mongodb://localhost:27017/lasgambusinas
# O Atlas / otro servidor:
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/lasgambusinas?retryWrites=true&w=majority

NODE_ENV=development
JWT_SECRET=cambia-este-secreto-en-produccion

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
